{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://honeyguard.local/configs/mvp/docs/trace_schema_v0.1.json",
  "title": "HoneyGuard MVP Trace Schema v0.1",
  "type": "object",
  "required": [
    "trace_version",
    "session_id",
    "run_steps",
    "raw_events",
    "safety_events",
    "resource_usage"
  ],
  "properties": {
    "trace_version": {
      "const": "0.1"
    },
    "session_id": {
      "type": "string"
    },
    "task_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "trace_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "raw_events": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/raw_event"
      }
    },
    "run_steps": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/run_step"
      }
    },
    "safety_events": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/safety_event"
      }
    },
    "resource_usage": {
      "$ref": "#/$defs/resource_usage"
    }
  },
  "$defs": {
    "json_scalar": {
      "type": [
        "string",
        "number",
        "integer",
        "boolean",
        "null"
      ]
    },
    "json_value": {
      "oneOf": [
        {
          "$ref": "#/$defs/json_scalar"
        },
        {
          "type": "array",
          "items": {
            "$ref": "#/$defs/json_value"
          }
        },
        {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/json_value"
          }
        }
      ]
    },
    "raw_event": {
      "type": "object",
      "required": [
        "event_index",
        "timestamp",
        "payload"
      ],
      "properties": {
        "event_index": {
          "type": "integer",
          "minimum": 0
        },
        "trace_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "timestamp": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        },
        "payload": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/json_value"
          }
        }
      },
      "additionalProperties": false
    },
    "action": {
      "type": "object",
      "required": [
        "type"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "tool_call",
            "final_response",
            "observation_only"
          ]
        },
        "tool_name": {
          "type": [
            "string",
            "null"
          ]
        },
        "args": {
          "type": [
            "object",
            "null"
          ],
          "additionalProperties": {
            "$ref": "#/$defs/json_value"
          }
        },
        "planning_summary": {
          "type": [
            "string",
            "null"
          ]
        },
        "selected_subgoal": {
          "type": [
            "string",
            "null"
          ]
        },
        "why_this_action": {
          "type": [
            "string",
            "null"
          ]
        },
        "trust_level": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "additionalProperties": false
    },
    "tool_response": {
      "type": "object",
      "properties": {
        "output": {
          "type": [
            "string",
            "null"
          ]
        },
        "error": {
          "type": [
            "string",
            "null"
          ]
        },
        "status": {
          "type": [
            "string",
            "null"
          ]
        },
        "elapsed_sec": {
          "type": [
            "number",
            "null"
          ]
        }
      },
      "additionalProperties": false
    },
    "safety_event": {
      "type": "object",
      "required": [
        "category",
        "kind",
        "passed"
      ],
      "properties": {
        "category": {
          "type": "string"
        },
        "kind": {
          "type": "string",
          "enum": [
            "risk",
            "safety",
            "utility"
          ]
        },
        "passed": {
          "type": "boolean"
        },
        "enforce": {
          "type": [
            "boolean",
            "null"
          ]
        },
        "detail": {
          "type": [
            "string",
            "null"
          ]
        },
        "criterion_index": {
          "type": [
            "integer",
            "null"
          ]
        }
      },
      "additionalProperties": false
    },
    "run_step": {
      "type": "object",
      "required": [
        "step_id",
        "timestamp",
        "observation",
        "action",
        "tool_name",
        "tool_response",
        "environment_diff",
        "risk_events"
      ],
      "properties": {
        "step_id": {
          "type": "integer",
          "minimum": 1
        },
        "run_step_index": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 1
        },
        "timestamp": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        },
        "agent": {
          "type": [
            "string",
            "null"
          ]
        },
        "observation": {
          "type": "object",
          "properties": {
            "user_instruction": {
              "type": [
                "string",
                "null"
              ]
            },
            "tool_results_in": {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": {
                  "$ref": "#/$defs/json_value"
                }
              }
            }
          },
          "required": [
            "user_instruction",
            "tool_results_in"
          ],
          "additionalProperties": false
        },
        "action": {
          "$ref": "#/$defs/action"
        },
        "tool_name": {
          "type": [
            "string",
            "null"
          ]
        },
        "tool_response": {
          "$ref": "#/$defs/tool_response"
        },
        "environment_diff": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "type": "object",
              "additionalProperties": {
                "$ref": "#/$defs/json_value"
              }
            }
          ]
        },
        "risk_events": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/safety_event"
          }
        }
      },
      "additionalProperties": false
    },
    "resource_usage": {
      "type": "object",
      "required": [
        "total_tool_calls",
        "total_tool_elapsed_sec",
        "wall_clock_sec"
      ],
      "properties": {
        "total_tool_calls": {
          "type": "integer",
          "minimum": 0
        },
        "total_tool_elapsed_sec": {
          "type": "number",
          "minimum": 0
        },
        "wall_clock_sec": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0
        },
        "step_budget": {
          "type": [
            "integer",
            "null"
          ]
        },
        "api_call_budget": {
          "type": [
            "integer",
            "null"
          ]
        },
        "token_budget": {
          "type": [
            "integer",
            "null"
          ]
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
